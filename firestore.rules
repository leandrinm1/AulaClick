rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users: readable by anyone authenticated, writable only by owner (limited fields)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['displayName', 'username', 'email', 'createdAt'])
        && !request.resource.data.keys().hasAny(['followersCount', 'followingCount', 'postsCount']);
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['followersCount', 'followingCount', 'postsCount', 'email', 'createdAt']);
    }

    // Wallets: NO client writes ever
    match /wallets/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Wallet transactions: read only by participants, no client writes
    match /walletTransactions/{txId} {
      allow read: if request.auth != null
        && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow write: if false;
    }

    // Products: readable by all authenticated, writable only by seller
    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.stock is int
        && request.resource.data.stock >= 0;
      allow update: if request.auth != null
        && resource.data.sellerId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['sellerId', 'rating', 'stock']);
      allow delete: if request.auth != null && resource.data.sellerId == request.auth.uid;
    }

    // Orders: NO client writes
    match /orders/{orderId} {
      allow read: if request.auth != null
        && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow write: if false;
    }

    // Posts: readable by all authenticated, writable by author
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 2000
        && !request.resource.data.keys().hasAny(['likesCount', 'commentsCount']);
      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['likesCount', 'commentsCount', 'authorId']);
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Post likes subcollection
    match /posts/{postId}/likes/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Comments subcollection
    match /posts/{postId}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Follows subcollection on users
    match /users/{userId}/following/{followedId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
